# -------------------------------------------------------
# MongoDB
# -------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=qiti_db
MONGO_SESSIONS_COLLECTION=sessions

# -------------------------------------------------------
# Qdrant
# -------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=your-qdrant-cloud-key   # only needed for Qdrant Cloud

QDRANT_COLLECTION_NAME=knowledge_base

# -------------------------------------------------------
# CORS (comma-separated list as a JSON array string)
# -------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# -------------------------------------------------------
# LLM keys (only set what you use)
# -------------------------------------------------------
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# -------------------------------------------------------
# General
# -------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
